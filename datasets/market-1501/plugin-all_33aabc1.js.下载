/**
 * HTML转义
 */
FileTreeView.prototype._escapeHtml = function (str) {
    if (!str) return '';
    return str.replace(/[&<>'"]/g, function (tag) {
        return {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '\'': '&#39;',
            '"': '&quot;'
        }[tag] || tag;
    });
};

FileTreeView.prototype.handleEvent = function () {
    var that = this;
    that.host.undelegate('.treeview-node');
    //handle
    that.host
        .delegate('.treeview-node', 'mouseover', function () {
            $(this).addClass('treeview-node-hover');
        })
        .delegate('.treeview-node', 'mouseout', function () {
            $(this).removeClass('treeview-node-hover');
        })
        .delegate('.treeview-node', 'click', function (e) {
            var me = $(this);
            var minus = me.hasClass('_minus');
            var nodeOn = me.hasClass('treeview-node-on');
            var empty = me.hasClass('treenode-empty');
            var pdl = me.attr('_pl');
            var waitHandle = me.hasClass('waitHandle');
            var dir = that._getPath($(this));
            var permitOpList = that._getPermit($(this));
            var collap = me.next('ul');

            // 团队空间专属逻辑
            if ($('.treeview-collab-space-theme').length > 0 || $('.treeview-collab-space-root').length > 0) {
                var $collabSpaceItem = me.closest('.treeview-collab-space-theme');
                var $collabSpaceRoot = me.closest('.treeview-collab-space-root');

                // 只有点击的是根节点本身时才处理（me.hasClass('treeview-root')）
                // 避免点击嵌套文件夹时误判为点击根节点
                if ($collabSpaceItem.length > 0 && me.hasClass('treeview-root')) {
                    var spaceId = $collabSpaceItem.attr('data-space-id');

                    // 不可用空间直接拦截并给出对应提示
                    var disabledReason = $collabSpaceItem.attr('data-disabled-reason');
                    if (disabledReason === 'expired') {
                        getContext().ui.tip({ msg: '该空间已到期，不支持选择', mode: 'caution' });
                        return;
                    } else if (disabledReason === 'visitor') {
                        getContext().ui.tip({ msg: '您是访客身份，暂不支持选择，如有需要请联系该空间管理员变更身份', mode: 'caution' });
                        return;
                    }

                    // 验证：检查空间是否到期或访客身份（兜底）
                    if (!validateCollabSpace(spaceId)) {
                        return;
                    }

                    // 更新当前选中的空间ID（使用实例属性）
                    that.spaceId = spaceId;

                    // 首层点击一个，收起其余（排除当前点击的）
                    Array.prototype.slice.call($('.treeview-collab-space-theme .treeview-root') || [], null).forEach(function (el) {
                        if (!$(el).is(me)) {
                            $(el).removeClass('_minus').find('.plus').removeClass('minus');
                            $(el).next('ul').addClass('treeview-collapse');
                        }
                    });

                    // 团队空间可以转存，启用确定按钮
                    $('.company-tree-confirm')
                        .removeClass('disabled no-permit no-root-dir-permit')
                        .attr('title', '确定');
                    $('.company-tree-newcreate').removeClass('disabled no-root-dir-permit');
                } else if ($collabSpaceRoot.length > 0 && me.hasClass('treeview-root')) {
                    // 直接进入团队空间根节点
                    var spaceId = $collabSpaceRoot.attr('data-space-id');

                    // 验证：检查空间是否到期或访客身份
                    if (!validateCollabSpace(spaceId)) {
                        return;
                    }

                    that.spaceId = spaceId;

                    // 团队空间可以转存，启用确定按钮
                    $('.company-tree-confirm')
                        .removeClass('disabled no-permit no-root-dir-permit')
                        .attr('title', '确定');
                    $('.company-tree-newcreate').removeClass('disabled no-root-dir-permit');
                }
            }

            // 企业专属逻辑：首层点击一个，收起其余
            if ($('.treeview-e-allfiles-theme').length > 0) {
                Array.prototype.slice.call($('.treeview-root') || [], null).forEach(function (el) {
                    // 已展开的根节点，收走
                    if (me.hasClass('treeview-root') && me.next('ul')) {
                        $(el).removeClass('_minus').find('.plus').removeClass('minus');
                        $(el).next('ul').addClass('treeview-collapse');
                    }
                });
                if (dir === '/' && $('.company-tree-confirm').attr('allRootDirInfo') === 'false') {
                    $('.company-tree-confirm')
                        .addClass('disabled no-permit no-root-dir-permit')
                        .attr('title', '无一级目录创建权限，请联系超级管理员修改');
                } else if (util.eCanTransfer(permitOpList)) {
                    // 企业有文件夹转存权限时，展示确定按钮
                    $('.company-tree-confirm')
                        .removeClass('disabled no-permit no-root-dir-permit')
                        .attr('title', '确定');
                } else {
                    $('.company-tree-confirm')
                        .addClass('disabled no-permit')
                        .attr('title', '无文件夹权限，无法进行转存');
                }

                if (dir === '/' && $('.company-tree-newcreate').attr('allRootDirInfo') === 'false') {
                    $('.company-tree-newcreate').addClass('disabled no-root-dir-permit');
                } else if (util.eCanCreateDir(permitOpList)) {
                    // 企业有创建文件夹权限时，展示新建文件夹按钮
                    $('.company-tree-newcreate').removeClass('disabled no-root-dir-permit');
                } else {
                    $('.company-tree-newcreate').addClass('disabled');
                }

                var logMap = {
                    'e-allfiles-theme': 'allfile',
                    'e-sharedir-theme': 'sharedir',
                    'e-personal-theme': 'personal'
                };
                var nodeTheme = me.parent().attr('node-theme');
                if (nodeTheme in logMap) {
                    getContext().log.send({
                        type: 'web_share_list_transfer_click_' + logMap[nodeTheme],
                        value: 'web-企业空间-转存-点击根目录'
                    });
                }
            }

            if (!nodeOn) {
                var fileList = window.locals.get('file_list') || [];
                var currFile = (fileList && fileList.length && fileList[0]) || {};
                var fileLogParam = {
                    fsid: currFile.fs_id || currFile.fsid || '',
                    md5: currFile.md5 || '',
                    file_name: currFile.server_filename || currFile.fileName || '',
                    file_path: currFile.path || '/'
                };
                chooseAreaPageLog.sendlog("chooseFileClk", {
                    ...getLogPublicParams(),
                    ...fileLogParam
                });
                that.host.find('.treeview-node-on').removeClass('treeview-node-on');
                me.addClass('treeview-node-on');
            }
            if (nodeOn && minus || empty) {
                me.removeClass('_minus').find('.plus').removeClass('minus');
                collap.addClass('treeview-collapse');
