        transferTask: function (task_id, savepath, cb) {
            var tProgress;
            var ISSVIP = window.locals.get('is_svip') === 1;
            var ISVIP = window.locals.get('is_vip') === 1;
            var type = 'novip';
            var msg = '尊贵的用户';
            var bindInfo = window.locals.get('bind_info'); // 转存操作时，一般异步数据已请求完，如果没有，走原有其它逻辑分支
            var isCollabSpace = pri.conf.currentItem && pri.conf.currentItem.type === 'collab';

            if (isCollabSpace) {
                type = 'work';
            } else if (pri.util.targetSpaceIsEnterprise()) {
                type = 'work';
            } else if (bindInfo && bindInfo._isValid) {
                type = 'work';
            } else if (ISSVIP) {
                type = 'svip';
                msg = '尊贵的超级会员';
            } else if (ISVIP) {
                type = 'vip';
                msg = '尊贵的会员';
            };

            var transferAgain = setInterval(function () {
                var taskUrl = pri.api.taskquery + '?taskid=' + task_id;
                if (isCollabSpace) {
                    // 团队共享空间任务查询
                    taskUrl = pri.api.collabTaskquery + '?taskid=' + task_id
                        + '&sharedSpaceId=' + pri.conf.currentItem.spaceId
                        + '&app_id=118511220';
                } else if (pri.util.targetSpaceIsEnterprise()) {
                    taskUrl = pri.api.eeTaskquery + '?taskid=' + task_id + '&cid='
                        + pri.conf.currentItem.cid + '&app_id=24029990';
                };
                $.get(taskUrl, function (data) {
                    if (!data) {
                        pri.util.transferTip('数据错误，请稍后重试');
                        clearInterval(transferAgain);
                        cb();
                        return;
                    }

                    if (data.errno === 0) {
                        // restapi.share_task_query err:0
                        // has task error
                        if (data.task_errno !== 0) {
                            var taskErrorMsg = '';

                            // partial files already existed
                            if (data.task_errno === -30) {
                                taskErrorMsg = '保存的文件部分已存在，' + createLink(savepath) + '已存在的文件';
                            } else {
                                taskErrorMsg = '文件保存失败，请稍候重试';
                            }

                            pri.util.transferTip(taskErrorMsg);
                            clearInterval(transferAgain);
                            cb();
                        } else {
                            // no task error
                            if (data.status === 'pending') {
                                pri.util.transferTip('正在准备保存，请稍候&hellip;', 'loading', type);
                            } else if (data.status === 'running') {
                                // running status
                                var taskProcess = 0;

                                if (tProgress !== undefined && !data.progress) {
                                    taskProcess = 0;
                                } else {
                                    taskProcess = Math.min(Math.max(parseInt(data.progress, 10), 0), 100);
                                }
                                tProgress = taskProcess;

                                pri.util.transferTip('正在保存，请稍候&hellip;&nbsp;&nbsp;&nbsp;已完成：'
                                    + taskProcess + '%', 'loading', type);
                            } else if (data.status === 'success') {
                                if ((type === 'svip' && data.total > 2000 && data.total <= 5000)
                                    || (type === 'vip' && data.total > 2000 && data.total <= 3000)) {
                                    msg += '，已为您成功保存' + data.total + '个文件。' + createLink(savepath);
                                    pri.util.transferTip(msg, 'success', type);
                                } else {
                                    // 保存成功
                                    pri.util.transferTaskSuccess(savepath);
                                }
                                clearInterval(transferAgain);
                                cb();
                            } else {
                                pri.util.transferTip('文件保存失败，请稍后重试');
                                clearInterval(transferAgain);
                                cb();
                            }
                        }
                    } else {
                        // restapi.share_task_query error
                        pri.util.transferTip('文件保存失败，请稍后重试');
                        clearInterval(transferAgain);
                        cb();
                    }
                }, 'json');
            }, 2500);
        },

