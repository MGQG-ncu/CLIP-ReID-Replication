function InvokeAppPopover(config) {
    this.target = config.target || null;
    this.ctx = config.ctx;
    this.isMac = checkIsMac();
    this.bdTitle = '';
    this.bdContent = '';
    this.bdSrc = '';
    this.bdButtonText = '';
    this.isHover = false;
    this.init();
}

InvokeAppPopover.prototype.init = function() {
    this.addName();
    this.bindEvent();
};

InvokeAppPopover.prototype.addName = function() {
    var that = this;
    getMergedPopupConfig({ nodeKey: 'back_pc_motivate_area' }, function(err, config) {
        if (err) {
            console.error(err);
        }
        that.bdTitle = config.title;
        that.bdContent = config.content;
        that.bdSrc = config.popperImage;
        that.bdButtonText = config.buttonText;
        that.updateContent();
    });
};

InvokeAppPopover.prototype.updateContent = function() {
    var popover = $('.nd-custom-popover');
    popover.find('.font_invork').text(this.bdTitle);
    popover.find('.invoke-desc').text(this.bdContent);
    popover.find('.Pcimg').css('backgroundImage', `url(${this.bdSrc})`);
    popover.find('.DownloadPC').text(this.bdButtonText);
};

InvokeAppPopover.prototype.bindEvent = function() {
    var that = this;
    var downloadPC = $('.DownloadPC');
    var macDownloadButtons = $('.mac-download-button');

    if (that.isMac) {
        // Mac 情况下，为两个下载按钮添加点击事件
        macDownloadButtons.eq(0).on('click', function() {
            that.downloadMacApp('intel');
        });

        macDownloadButtons.eq(1).on('click', function() {
            that.downloadMacApp('arm');
        });
    } else {
        // 非 Mac 情况下，为单个下载按钮添加点击事件
        downloadPC.on('click', function() {
            that.handlePopoverAction();
        });
    }
};

