var $ = require('base:widget/libs/jquerypacket.js');
var getContext = require('disk-share:widget/plugin/shareFileSave/context.js').getContext;
var util = require('disk-share:widget/system/util/util.js');
var chooseAreaPageLog = require('disk-share:widget/system/util/chooseAreaPageLog.js');
var vipStatus = require('base:widget/vip/vip.js');
var context = require('system-core:context/context.js').instanceForSystem;

// 团队空间角色：4 = 访客
var COLLAB_ROLE_VISITOR = 4;

var folderCacheConfig = {
    api: '',
    params: {
        dir: '/',
        order: 'name',
        desc: 0
    },
    // 当超过limit的时候，再拉去更多的数据
