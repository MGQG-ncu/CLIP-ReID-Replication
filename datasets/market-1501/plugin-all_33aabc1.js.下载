// 获取key
FileTreeDialog.prototype._getSaveTransferPathKey = function () {
    if (this.activeItem && this.activeItem.type === 'person') {
        return window.locals.get('username').replace(/@/gi, '') + '_transfer_save_path';
    } else if (this.activeItem && this.activeItem.type === 'sync') {
        return window.locals.get('username').replace(/@/gi, '') + '_sync_transfer_save_path';
    } else if (this.activeItem && this.activeItem.type === 'collab') {
        return window.locals.get('username').replace(/@/gi, '') + '_collab_transfer_save_path';
    }
};
// 保存key
FileTreeDialog.prototype.saveTransferPath = function (path) {
    var saveData = {
        path: path,
        timestamp: new Date().getTime(),
        type: this.activeItem && this.activeItem.type || 'person',
        spaceId: this.activeItem && this.activeItem.spaceId || '',
        spaceName: this.activeItem && this.activeItem.name || ''
    };

    // 如果是团队共享空间，从 FileTree 获取当前选中的空间信息
    if (saveData.type === 'collab') {
        var currentSpaceId = FileTree.spaceId || saveData.spaceId;
        if (currentSpaceId) {
            saveData.spaceId = currentSpaceId;
            // 从团队空间列表中获取空间名称
            var collabSpaceList = this.collabSpaceList || [];
            for (var i = 0; i < collabSpaceList.length; i++) {
                // 使用 == 宽松比较，因为 spaceId 可能是数字或字符串
                if (collabSpaceList[i].spaceId == currentSpaceId) {
                    saveData.spaceName = collabSpaceList[i].name;
                    break;
                }
            }
        }
    }

    storage.setItem(this._getSaveTransferPathKey(), JSON.stringify(saveData));
    storage.setItem(window.locals.get('username').replace(/@/gi, '') + '_cur_transfer_save_path', path + '?' + new Date().getTime());
};
// 显示最近保存路径
FileTreeDialog.prototype._showSavePathRecent = function () {
    var self = this;

    // 使用 _getLastSaveData 获取最近保存的数据（跨空间类型）
    var saveData = this._getLastSaveData();
    if (!saveData) {
        return;
    }

    if (saveData.path && saveData.path.indexOf('/_pcs_.appdata/ent/') === 0) {
        return;
    }

    var savePath = saveData.path;
    var timeStramp = saveData.timestamp;
    var displayPath = savePath;

    // 格式化显示路径
    if (saveData.type === 'sync' && savePath.indexOf('/_pcs_.workspace') === 0) {
        displayPath = '同步空间' + savePath.replace('/_pcs_.workspace', '');
    } else if (saveData.type === 'collab') {
        // 团队共享空间显示格式：空间名称/文件夹/.../文件夹
        var spaceName = saveData.spaceName;
        // 如果没有保存空间名称，尝试从空间列表中获取
        if (!spaceName && saveData.spaceId) {
            var collabSpaceList = this.collabSpaceList || [];
            for (var i = 0; i < collabSpaceList.length; i++) {
                // 使用 == 宽松比较，因为 spaceId 可能是数字或字符串
                if (collabSpaceList[i].spaceId == saveData.spaceId) {
                    spaceName = collabSpaceList[i].name;
                    break;
                }
            }
        }
        if (spaceName) {
            displayPath = spaceName + savePath;
        } else {
            displayPath = '团队共享空间' + savePath;
        }
    }

    var currentTime = new Date().getTime();
    var timeDiff = currentTime - timeStramp;

    var item = $('.save-path-item');
    if (timeDiff <= self._mSaveTime && timeDiff >= 0) {
        if (item.length) {
            item.html('<span class="save-chk-io"></span>最近保存路径：' + displayPath);
            item.attr('title', displayPath);
            item.removeClass('check');
        } else {
            self.dialog.$dialog.find('.dialog-body').after('<div class="save-path-item" title="' + displayPath + '">' +
                '<span class="save-chk-io"></span>最近保存路径：' + displayPath + '</div>');
        }
        self._mShowRecentSavePathFlag = 1;
        self._mSavePathRecent = savePath;
        // 保存完整的保存数据，用于后续展开空间
        self._mSaveDataRecent = saveData;
    } else {
        item.length && item.remove();
        self._mShowRecentSavePathFlag = 0;
        self._mSavePathRecent = null;
        self._mSaveDataRecent = null;
    }
};
// 获取选中的最近保存地址
FileTreeDialog.prototype._getSavePath = function () {
    if ($('.save-path-item').hasClass('check')) {
        return this._mSavePathRecent;
    }
    return null;
};
// savePath事件绑定
FileTreeDialog.prototype.bindSavePathEvent = function () {
    var that = this;
    this.dialog.$dialog.on('click', '.save-path-item', function () {
        var thisClass = $(this).attr('class');
        if (thisClass.indexOf('check') >= 0) {
            $(this).removeClass('check');
        } else {
            $(this).addClass('check');
        }
    });
    this.dialog.$dialog.on('click', '.dialog-close', function () {
        that.destroy();
    });
};

// 切换空间事件绑定
FileTreeDialog.prototype.bindSwitchSpaceEvent = function () {
    var that = this;
    this.dialog.$dialog.on('click', '#dynamicHeaderClose', function () {
        that.destroy();
    });
    $('.dialog-header-tab-bar').on('click', function (e) {
        // 切换空间隐藏说明提示
        that.hideTips();
        $('.isSyncTips').hide();
        var thisClass = $(this).attr('class');
        if (thisClass.indexOf('show-tab') >= 0) {
            $(this).removeClass('show-tab');
            $('.switch-space-container').hide();
        } else {
            $(this).addClass('show-tab');
            $('.switch-space-container').show();
        }
        e.stopPropagation();
        getContext().log.send({
            type: 'url_sto_cha_clk',
            value: '切换空间tab点击'
        });
    });
    this.dialog.$dialog.on('click', '.switch-space-list-item', function (e) {
        e.stopPropagation();
        $('.switch-space-list-item').removeClass('switch-space-list-item-active');
        $(this).addClass('switch-space-list-item-active');
        var type = $(this).data('type');
        var cid = $(this).data('cid') || '';
        var spaceId = $(this).data('spaceid') || '';

        setTimeout(function () {
            $('.switch-space-container').hide();
            that.switchSpaceCallback && that.switchSpaceCallback({
                type: type,
                cid: cid,
                spaceId: spaceId
            });
        }, 200);
        if (type === 'sync') {
            getContext().log.send({
                type: 'url_sto_syn_clk',
                value: '切换空间面板-选择同步空间点击'
            });
        } else if (type === 'collab') {
            getContext().log.send({
                type: 'url_sto_collab_clk',
                value: '切换空间面板-选择团队共享点击'
            });
        } else {
            getContext().log.send({
                type: 'share_link_choose_space',
                from: type
            });
        }
    });
    this.dialog.$dialog.on('click', '.dialog-close', function () {
        that.hide();
    });
};

// 气泡提示
FileTreeDialog.prototype._tips = function () {
    // 未命中同步空间切换
    if (!this.isShowSyncSpace) {
        return;
    }
    var tipsConf = this.tipsConf;
    var showTipsTimeStamp = localStorage.getItem('show_tips_time') || 0;
    var tipsTxt = tipsConf.isSvip ? tipsConf.svip_user : tipsConf.normal_user;

    // 用户已是同步空间用户，功能更新首次进入转存弹窗展示一次
    if (showTipsTimeStamp && tipsConf.isWorkSpaceUser) {
        return;
    }

    var nowTimeStamp = new Date().getTime();
    var tipsShowTime = localStorage.getItem('tips_show_time') || 0;
    var showTimeDiff = nowTimeStamp - showTipsTimeStamp;
    var SEVENT_DAY_TIME_STAMP = 7 * 24 * 60 * 60 * 1000;
    // 第一次打开出现同步空间引导，第二次打开出现转存引导
    // 非同步空间首次展示后，并未转存，则七天后再次展示一次,最多展示两次
    if (!tipsConf.isWorkSpaceUser
        && ((showTimeDiff < SEVENT_DAY_TIME_STAMP)
        || tipsShowTime > 1)) {
        return;
    }
    localStorage.setItem('tips_show_time', ++tipsShowTime);
    localStorage.setItem('show_tips_time', nowTimeStamp);

    var isSyncSpaceUserTips = [
        '<div class="isSyncTips">',
            '<div class="isSyncTips-container">',
                '<div class="isSyncTips-container-desc">' + tipsConf.title + '</div>',
            '</div>',
        '</div>'
    ];
    var isNotSyncSpaceUserTips = [
        '<div class="isNotSyncTips">',
            '<div class="isNotSyncTips-container">',
                '<div class="isNotSyncTips-container-icon"></div>',
                '<div class="isNotSyncTips-container-content">',
                    '<div class="isNotSyncTips-container-content-title">' + tipsConf.title + '</div>',
                    '<div class="isNotSyncTips-container-content-tips">' + tipsTxt + '</div>',
                    '<div class="isNotSyncTips-container-content-btn">我知道了</div>',
                '</div>',
            '</div>',
        '</div>'
    ];
    var itemtips = tipsConf.isWorkSpaceUser ? isSyncSpaceUserTips : isNotSyncSpaceUserTips;
    context.log.send({
        type: tipsConf.isWorkSpaceUser ? 'sto_syn_old_dis' : 'sto_syn_new_dis',
        value: tipsConf.isWorkSpaceUser ? '同步空间老用户气泡展现' : '同步空间老用户气泡展现'
    });
    return itemtips.join('');
};

// 气泡提示关闭
FileTreeDialog.prototype.hideTips = function () {
    // eslint-disable-next-line
    this.dialog.$dialog.find('.isNotSyncTips').on('click', '.isNotSyncTips-container-content-btn', function() {
        $('.isNotSyncTips').hide();
    });
};


/**
 * 处理文件选择器变更事件
 * @param {string} type - 选择类型 ('single'|'all')
 * @param {string} text - 选择文本
 */
FileTreeDialog.prototype.handleSelectorChange = function(type, text) {
    sessionStorage.setItem('transfer_dialog_type', type);
};

/**
 * 获取当前选中的空间信息
 * @returns {Object} 包含 type, cid, spaceId, name 的对象
 */
FileTreeDialog.prototype.getActiveItem = function() {
    var activeItem = {
        type: this.activeItem && this.activeItem.type || 'person',
        cid: this.activeItem && this.activeItem.cid || '',
        spaceId: this.activeItem && this.activeItem.spaceId || '',
        name: this.activeItem && this.activeItem.name || ''
    };

    // 如果是团队共享空间，从 FileTree 获取当前选中的 spaceId
    if (activeItem.type === 'collab') {
        var currentSpaceId = FileTree.spaceId || activeItem.spaceId;
        if (currentSpaceId) {
            activeItem.spaceId = currentSpaceId;
            // 从团队空间列表中获取空间名称
            var collabSpaceList = this.collabSpaceList || [];
            for (var i = 0; i < collabSpaceList.length; i++) {
                // 使用 == 宽松比较，因为 spaceId 可能是数字或字符串
                if (collabSpaceList[i].spaceId == currentSpaceId) {
                    activeItem.name = collabSpaceList[i].name;
                    break;
                }
            }
        }
    }

    return activeItem;
};

module.exports = new FileTreeDialog();
 
