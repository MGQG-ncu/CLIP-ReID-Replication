};
FileTreeView.prototype.resetApi = function () {
    if (folderCacheConfig._api) {
        folderCacheConfig.api = folderCacheConfig._api;
        folderCacheConfig.params = JSON.parse(JSON.stringify(folderCacheConfig._params));
        folderCacheConfig._api = '';
