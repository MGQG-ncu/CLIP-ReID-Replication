        toFriendlyFileSize: function (size, isBit) {
            var B = 1024;
            var K = B * B; // 1024^2
            var M = K * B; // 1024^3
            var G = M * B; // 1024^4;
            var LG = M * 1000; // 1024^3 * 1000
            var BG = M * 10000;
            if (isBit && typeof size === 'number') {
                size = size / 8;
            }
            if (typeof size === 'number' || (typeof size === 'string' && /^[\d.]+$/.test(size))) {
                if (size < B) {
                    size = Math.round(size) + 'B';
                } else if (size < K) {
                    size = Math.round(size / B) + 'KB';
                } else if (size < M) {
                    size = (size / K).toFixed(1) + 'M';
                } else if (size < LG) {
                    size = (size / M).toFixed(1) + 'G';
                } else if (size < BG) {
                    size = Math.round(size / M) + 'G';
                } else {
                    size = Math.round(size / G) + 'T';
                }
            } else {
                size = '-';
            }
            size = size.replace('.0', '');
            return size;
        },
        getFirstWord: function (name) {
            if (name) {
                return name.substr(0, 1).toLocaleUpperCase();
            }
            return '';
        },
        serviceInit: function () {
            pri.conf.wait = 2;
            if (pri.conf.fileObj.length === 0) {
                pri.util.transferTip('请选择一下你要保存的文件哦');
                return;
            }
            // this is where transferFiles begins executing
            if (pri.util.isLoggedIn()) {
                // 获取预先加载的公司列表数据和同步空间是否展示的数据
                var companyListData = window.locals.get('preFetchCompanyList') || [];
                var isShowSync = window.locals.get('preFetchIsShowSyncSpace') || false;
                if (companyListData.length || isShowSync) {
                    pri.util.getQuota(function (userInfo) {
                        pri.conf.isShowSyncSpace = isShowSync;
                        var lastSaveSpaceStr = storage.getItem('lastTimeSaveSpace_' + window.locals.get('uk'));
                        var lastSaveSpace = {};
                        var params = {};
                        if (lastSaveSpaceStr && JSON.parse(lastSaveSpaceStr)) {
                            lastSaveSpace = JSON.parse(lastSaveSpaceStr);
                            if ((lastSaveSpace.type === 'sync') && !isShowSync) {
                                lastSaveSpace = {};
                            }
                            if (lastSaveSpace.cid) {
                                companyListData.forEach(function (n) {
                                    if (+n.cid === +lastSaveSpace.cid) {
                                        pri.conf.currentItem = n;
                                        params = n;
                                        params.type = 'company';
                                    }
                                });
                            }
                        }
                        pri.util.openDialog(params, {
                            isShowChangeTab: true,
                            isShowSyncSpace: isShowSync,
                            companyList: companyListData,
                            collabSpaceList: window.locals.get('preFetchCollabSpaceList') || [],
                            userInfo: userInfo,
                            lastSaveSpace: lastSaveSpace || {}
                        });
                        getContext().log.send({
                            type: 'url_sto_cha_dis',
                            value: '切换空间tab展现'
                        });
                    });
                } else {
                    pri.conf.currentItem = {};
                    pri.util.openDialog();
                }
            }
        },
        getQuota: function (callback) {
            $.ajax({
                url: pri.api.quota,
                data: {
                    checkexpire: 1,
                    checkfree: 1
                },
                type: 'get',
                dataType: 'json',
                success: function (t) {
                    var avator = window.locals.get('photo');
                    var userName = window.locals.get('username');
                    var used = t.used || 0;
                    var total = t.total || 0;
                    callback && callback({
                        used: pri.util.toFriendlyFileSize(used),
                        total: pri.util.toFriendlyFileSize(total),
                        name: userName,
                        avator: avator
                    });
                }
            });
