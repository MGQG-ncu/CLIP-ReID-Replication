FileTreeView.prototype._buildTreeView = function (args) {
    var that = this;

    var dir = args.dir || '/';
    var host = args.host || that.host.find('.treeview-root-content');
    var pl = args.pl;

    var loading = host.parent().find('.minus');
    loading.addClass('treeview-leaf-loading');

    // 企业共享一级目录需调另外接口
    if (dir === '/_pcs_.appdata/ent/sharedir/') {
        this.setShareDirApi();
    }
    // 用cacheManage
    this.folderCache.updateKey(dir);
    this.folderCache.getCacheData(-1, function (list) {
        // 获取文件列表
        var html = '';
        for (var i = 0, item; i < list.length; i++) {
            item = list[i];
            if (+item.isdir !== 1) {
                continue;
            }
            html += that._tpl({
                fileName: item.server_filename,
                dirEmpty: item.dir_empty,
                pdleft: pl,
                path: item.path,
                permit: item.permit_code,
                ownerUk: item.owner_uk,
                share: item.share,
                permitOpList: item.permit_op_list
            });
        }

        host.html(html).attr('_pl', pl + 'px');

        // 获取【我的资源】
        var mySourceItemArr = list.map(function (item, index) {
            if (item.server_filename === '我的资源') {
                return {item: item, index: index};
            }
        }).filter(function (item) {return item;});

        if (mySourceItemArr.length) {
            var mySourceItem = mySourceItemArr[0]; // 【我的资源】
            setTimeout(function () {
                // scroll至【我的资源】
                var hostChild = host.children();
                if (hostChild.length === 0) {
                    return;
                }
                var itemHeight = hostChild[0].clientHeight;
                that.host.scrollTop((mySourceItem.index + 1) * itemHeight);

                // 展开【我的资源】
                var collapseItem = hostChild.eq(mySourceItem.index);
                var collapseItemChild = collapseItem.children();

                if (collapseItemChild && collapseItemChild.click && typeof collapseItemChild.click === 'function') {
                    collapseItemChild.click();
                };
            }, 0);
        }

        loading.removeClass('treeview-leaf-loading');
        that.resetApi();
    }, function () {
        loading.removeClass('treeview-leaf-loading');
        getContext().ui.tip({
            mode: 'caution',
            msg: '列表加载失败，请稍后重试&hellip;'
        });
        that.resetApi();
    });
};

/**
 * 生成团队空间默认头像（首字 + 渐变背景）
 * @param {string} name - 空间名称
 * @param {number} size - 头像尺寸，默认44
 * @returns {string} data URL 格式的 SVG 图片
 */
FileTreeView.prototype._generateCollabAvatar = function (name, size) {
    size = size || 44;
    var firstChar = name ? name.charAt(0) : '?';
    var radius = 5;
    var padding = 4;
    var contentSize = size - padding * 2;
    var fontSize = Math.round(contentSize * 0.45);

    // 渐变色定义
    var gradientStart = '#1AA3FF';
    var gradientEnd = '#CCEBFF';

    var gradientRect = '<defs>'
        + '<linearGradient id="collabGrad" x1="0%" y1="0%" x2="100%" y2="100%">'
        + '<stop offset="0%" style="stop-color:' + gradientStart + '"/>'
        + '<stop offset="49.64%" style="stop-color:' + gradientStart + '"/>'
        + '<stop offset="100%" style="stop-color:' + gradientEnd + '"/>'
        + '</linearGradient>'
        + '</defs>'
        + '<rect x="' + padding + '" y="' + padding + '" '
        + 'width="' + contentSize + '" height="' + contentSize + '" '
        + 'rx="' + radius + '" fill="url(#collabGrad)"/>';

    var textElement = '<text'
        + ' x="' + (size / 2) + '"'
        + ' y="' + (size / 2) + '"'
        + ' dominant-baseline="central"'
        + ' text-anchor="middle"'
        + ' fill="white"'
        + ' font-size="' + fontSize + '"'
        + ' font-weight="500"'
        + ' font-family="PingFang SC, Microsoft YaHei, sans-serif"'
        + '>' + firstChar + '</text>';

    var svg = '<svg xmlns="http://www.w3.org/2000/svg" '
        + 'width="' + size + '" '
        + 'height="' + size + '" '
        + 'viewBox="0 0 ' + size + ' ' + size + '">'
        + gradientRect
        + textElement
        + '</svg>';

    return 'data:image/svg+xml,' + encodeURIComponent(svg);
};

/**
 * 构建团队空间文件夹树视图
 */
FileTreeView.prototype._buildCollabSpaceTreeView = function (args) {
    var that = this;
    var spaceId = args.spaceId;
    var host = args.host;
    var pl = args.pl || 15;
    var path = args.path || '/';

    var loading = host.parent().find('.minus');
    loading.addClass('treeview-leaf-loading');

    // 调用团队空间文件列表接口
    $.ajax({
        url: '/api/ostp/file/list',
        type: 'POST',
        data: {
            sharedSpaceId: spaceId,
            path: path,
            app_id: 118511220,
            page_index: 1,
            page_size: 1000,
            order: 'server_ctime',
            desc: 1,
            path_type: 1,
            isShowSubDirNums: 1,
            folder: 1,
            show_empty: true
        },
        dataType: 'json',
        success: function (res) {
            // 接口返回数据在 res.data.list 中
            var list = (res.data && res.data.list) || [];
            var html = '';
            for (var i = 0, item; i < list.length; i++) {
                item = list[i];
                // 只显示文件夹
                if (+item.isdir !== 1) {
                    continue;
                }
                // 根据子目录数量判断是否为空文件夹
                var dirEmpty = item.dir_empty === 1;
                html += that._tpl({
                    fileName: item.server_filename,
                    dirEmpty: dirEmpty,
                    pdleft: pl,
                    path: item.path,
                    permit: item.permit_code || 300,
                    ownerUk: item.owner_uk || '',
                    share: item.share || false,
                    permitOpList: item.permit_op_list || util.eAllPermissions()
                });
            }
            host.html(html).attr('_pl', pl + 'px');
            loading.removeClass('treeview-leaf-loading');
        },
        error: function () {
            loading.removeClass('treeview-leaf-loading');
            getContext().ui.tip({
                mode: 'caution',
                msg: '团队空间列表加载失败，请稍后重试&hellip;'
            });
        }
    });
};

FileTreeView.prototype._tpl = function (args) {
    var vPleft = args.pdleft;
    var vPath = args.path;
    var vPermitOpList = args.permitOpList || util.eAllPermissions();
    var vOwnerUk = args.ownerUk || '';
    var vShare = args.share ? 'treenode-share' : '';
    var vDirEmpty = args.dirEmpty ? 'treenode-empty' : '';
    var vNodeOn = args.nodeOn ? 'treeview-node-on' : '';
    var vThemeClass = args.themeClass || '';
    var vNodeRoot = args.nodeRoot ? 'treeview-root' : '';
    var vRoot_cont = args.nodeRoot ? 'treeview-root-content' : '';
    var vMinus = args.minus ? 'minus' : '';
    var v_Minus = args.minus ? '_minus' : '';
    var vCollapse = args.minus ? '' : 'treeview-collapse';
    var tpl = [
        '<li class="treeview-%themeClass%" node-theme=%themeClass%>',
        '<div class="treeview-node %dirEmpty% %node-share% %node-on% %node-root% %_minus%"',
        '_pl="%pl%" style="padding-left:%pl%">',
        '<span class="treeview-node-handler">',
        // '<em class="b-in-blk plus icon-operate %minus%" ></em>',
        '<dfn class="b-in-blk treeview-ic"></dfn>',
        '<span class="treeview-txt" node-path="%nodePath%" permit-op-list="%permitOpList%"',
        'owner-uk="%ownerUk%">%fileName%</span>',
        '<em class="b-in-blk plus icon-operate %minus%" ></em>',
        '</span>',
        '</div>',
        '<ul class="treeview %node-root-cont% treeview-content %collapse%" _pl="%pl2%"></ul>',
        '</li>'
    ];
    return tpl.join('').replace(/%fileName%/g, this.getNameFromPath(vPath, args.cid))
        .replace(/%nodePath%/g, vPath)
        .replace(/%permitOpList%/g, vPermitOpList)
        .replace(/%themeClass%/g, vThemeClass)
        .replace(/%node-root%/g, vNodeRoot)
        .replace(/%ownerUk%/g, vOwnerUk)
        .replace(/%node-share%/g, vShare)
        .replace(/%node-on%/g, vNodeOn)
        .replace(/%collapse%/g, vCollapse)
        .replace(/%pl%/g, vPleft + 'px')
        .replace(/%pl2%/g, (vPleft + 15) + 'px')
        .replace(/%node-root%/g, vNodeRoot)
        .replace(/%minus%/g, vMinus)
        .replace(/%_minus%/g, v_Minus)
        .replace(/%node-root-cont%/g, vRoot_cont)
        .replace(/%dirEmpty%/g, vDirEmpty);
};

