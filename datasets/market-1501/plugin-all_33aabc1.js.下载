/**
 * 显示对话框
 * @param options
 */
FileTreeDialog.prototype.show = async function (options) {
    var _params = options.params || {};

    // 先设置 options 以确保 collabSpaceList 被初始化
    this.setOptions(options);

    // 判断是否是首次打开对话框（没有指定 type）
    var isFirstOpen = !_params.type;

    // 尝试从上次保存记录中恢复空间信息（仅在首次打开时恢复）
    var lastSaveData = this._getLastSaveData();
    if (lastSaveData && isFirstOpen) {
        // 首次打开时，恢复上次保存的空间类型和 ID
        _params.type = lastSaveData.type || 'person';
        if (lastSaveData.type === 'collab' && lastSaveData.spaceId) {
            var collabSpaceList = this.collabSpaceList || [];
            // 检查 spaceId 是否在当前团队列表中存在
            var foundSpace = null;
            for (var i = 0; i < collabSpaceList.length; i++) {
                // 使用 == 宽松比较，因为 spaceId 可能是数字或字符串
                if (collabSpaceList[i].spaceId == lastSaveData.spaceId) {
                    foundSpace = collabSpaceList[i];
                    break;
                }
            }
            if (foundSpace) {
                // 找到了，使用团队列表中的信息
                _params.spaceId = foundSpace.spaceId;
                _params.spaceName = foundSpace.name;
            } else if (collabSpaceList.length > 0) {
                // 没找到，打开第一个团队
                _params.spaceId = collabSpaceList[0].spaceId;
                _params.spaceName = collabSpaceList[0].name;
            } else {
                // 团队列表为空，不设置 spaceId，显示空状态
                _params.spaceId = '';
                _params.spaceName = '';
            }
        } else if (lastSaveData.type === 'company' && lastSaveData.cid) {
            _params.cid = lastSaveData.cid;
        }
    }

    this.buildDialog(_params);
    var isEnt = !!_params.cid || !!this.activeItem.cid;
    var isCollab = this.activeItem && this.activeItem.type === 'collab';
    // 使用 _params 构建 treeParams，确保恢复的空间信息被正确传递
    var treeParams = {
        type: _params.type || this.params.type || this.activeItem.type || '',
        cid: _params.cid || this.params.cid || this.activeItem.cid || '',
        spaceId: _params.spaceId || this.params.spaceId || this.activeItem.spaceId || ''
    };

    FileTree.build(this.dialog && this.dialog.$dialog.find('.file-tree-container'), treeParams);

    FileTree.refresh(treeParams);
    this.changeTitle();
    this.dialog.show();

    // 显示最近保存路径（个人空间、同步空间、团队共享空间都显示）
    var recentItem = $('.save-path-item');
    recentItem.length && recentItem.remove();
    this._showSavePathRecent();

    // 如果是团队共享空间且有最近保存的空间信息，自动展开该空间
    if (isCollab && this._mSaveDataRecent && this._mSaveDataRecent.spaceId) {
        // 设置 FileTree 的 spaceId，以便后续操作使用
        FileTree.spaceId = this._mSaveDataRecent.spaceId;
    }

    return this;
};

/**
 * 获取上次保存的数据（根据时间戳返回最近的记录）
 */
FileTreeDialog.prototype._getLastSaveData = function () {
    // 检查各空间的保存记录
    var keys = [
        { key: window.locals.get('username').replace(/@/gi, '') + '_collab_transfer_save_path', type: 'collab' },
        { key: window.locals.get('username').replace(/@/gi, '') + '_sync_transfer_save_path', type: 'sync' },
        { key: window.locals.get('username').replace(/@/gi, '') + '_transfer_save_path', type: 'person' }
    ];

    var latestData = null;
    var latestTimestamp = 0;

    for (var i = 0; i < keys.length; i++) {
        var savePathValue = storage.getItem(keys[i].key);
        if (savePathValue) {
            try {
                var saveData = JSON.parse(savePathValue);
                // 检查是否在有效期内（3天）
                var timeDiff = new Date().getTime() - (saveData.timestamp || 0);
                if (timeDiff <= this._mSaveTime && timeDiff >= 0) {
                    // 找出时间戳最大的（最近的）记录
                    if (saveData.timestamp > latestTimestamp) {
                        saveData.type = saveData.type || keys[i].type;
                        latestData = saveData;
                        latestTimestamp = saveData.timestamp;
                    }
                }
            } catch (e) {
                // 兼容旧格式
                var savePathValueArr = savePathValue.split('?');
                if (savePathValueArr.length >= 2) {
                    var timestamp = parseInt(savePathValueArr[1]) || 0;
                    var timeDiff = new Date().getTime() - timestamp;
                    if (timeDiff <= this._mSaveTime && timeDiff >= 0) {
                        // 找出时间戳最大的（最近的）记录
                        if (timestamp > latestTimestamp) {
                            latestData = {
                                path: savePathValueArr[0],
                                timestamp: timestamp,
                                type: keys[i].type
                            };
                            latestTimestamp = timestamp;
                        }
                    }
                }
            }
        }
    }
    return latestData;
};

