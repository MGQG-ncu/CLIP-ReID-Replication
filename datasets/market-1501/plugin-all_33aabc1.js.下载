        this.activeItem.spaceId = _params.spaceId;
    } else if (!_params.type && this.lastSaveSpace.spaceId) {
        this.activeItem.spaceId = this.lastSaveSpace.spaceId;
    } else {
        this.activeItem.spaceId = '';
    }
    if (this.activeItem.type === 'person') {
        this.activeItem.avator = this.userInfo.avator;
        this.activeItem.name = this.userInfo.name;
        this.activeItem.cid = '';
    } else if (this.activeItem.type === 'company') {
        var actId = this.activeItem.cid;
        var actCompItem = this.companyList.filter(function (n) {
            return +n.cid === +actId;
        });
        if (actCompItem && actCompItem.length) {
            this.activeItem.avator = actCompItem[0].avator;
            this.activeItem.name = actCompItem[0].name;
            this.activeItem.avatorImg = actCompItem[0].avatorImg;
        }
    } else if (this.activeItem.type === 'collab') {
        // 团队共享空间
        this.activeItem.cid = '';
        // 如果有 spaceId，从列表中获取空间信息
        var collabSpaceList = this.collabSpaceList || [];
        if (this.activeItem.spaceId && collabSpaceList.length > 0) {
            for (var i = 0; i < collabSpaceList.length; i++) {
                if (collabSpaceList[i].spaceId === this.activeItem.spaceId) {
                    this.activeItem.name = collabSpaceList[i].name;
                    this.activeItem.avatorImg = collabSpaceList[i].avatorImg;
                    break;
                }
            }
        } else if (_params.spaceName) {
            // 如果没有找到空间但传入了空间名称，使用传入的名称
            this.activeItem.name = _params.spaceName;
        }
    } else {
        this.activeItem.cid = '';
    }

    var tabBarTpl = this._headerTpl({
        htmlType: 'tabBar',
        type: this.activeItem.type,
        name: this.activeItem.name,
        avator: this.activeItem.avator,
        avatorImg: this.activeItem.avatorImg
    });
    return tabBarTpl;
};

