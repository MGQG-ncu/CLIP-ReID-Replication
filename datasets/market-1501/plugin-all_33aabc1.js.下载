            if (!params) {
                params = {};
            }
            pri.util.reportLogger(params);
            pri.util.depositPath(function (savepath) {
                // 使用 pri.conf.currentItem 作为最新的空间信息来源
                // 因为它在 confirm 回调中被正确更新了
                var currentParams = {
                    type: pri.conf.currentItem.type || params.type || '',
                    cid: pri.conf.currentItem.cid || params.cid || '',
                    spaceId: pri.conf.currentItem.spaceId || params.spaceId || '',
                    name: pri.conf.currentItem.name || params.name || ''
                };
                var paths = pri.util.getFilePaths(pri.conf.fileObj);
                var ajaxParams = pri.util.preparePostParams(savepath, paths, currentParams);
                pri.util.execTransfer(savepath, ajaxParams, currentParams);
                pri.conf.tipsConf.type = currentParams && currentParams.type;
            }, params, tabConfig);
        },
        chooseSpace: function (list, userInfo) {
            chooseSpaceDialog.show({
                title: '选择存储位置',
                confirm: function (selectedData) {
                    shareFileDialog.hide();
                },
                closeCallback: function (params) {
                    if (!params.cid) {
                        pri.conf.currentItem = {};
                    } else {
                        list.forEach(function (n) {
                            if (n.cid + '' === params.cid) {
                                pri.conf.currentItem = n;
                            }
                        });
                    }
                    pri.util.openDialog(params);
                },
                list: list,
                userInfo: userInfo
            });
        },
        mapList: function (list) {
            var newList = list.map(function (n) {
                var orgInfo = n.orgInfo;
                return {
                    ciduk: orgInfo.ciduk,
                    name: orgInfo.name,
                    // eslint-disable-next-line
                    desc: '空间容量' + pri.util.toFriendlyFileSize(orgInfo.company_quota_used) + '/' + pri.util.toFriendlyFileSize(orgInfo.company_quota),
                    used: pri.util.toFriendlyFileSize(orgInfo.company_quota_used),
                    total: pri.util.toFriendlyFileSize(orgInfo.company_quota),
                    cid: orgInfo.cid,
                    avator: pri.util.getFirstWord(orgInfo.name),
                    brief: orgInfo.brief,
                    productType: orgInfo.product_type,
                    role: orgInfo.role,
                    total_user_num: orgInfo.total_user_num,
                    avatorImg: orgInfo.logo,
                    certStatus: orgInfo.cert_status,
                    cancelCert: orgInfo.cancel_status
                };
            });
            return newList;
        },
        getCompanyListFn: function (fn) {
            $.ajax({
                url: pri.api.getCompanyList,
                data: {},
                type: 'get',
                dataType: 'json',
                success: function (res) {
                    pri.conf.wait--;
                    var list = res.data;
                    fn && fn(list || []);
                },
                error: function () {
                    pri.conf.wait--;
                    fn && fn([]);
                }
            });
        }
    }
};

