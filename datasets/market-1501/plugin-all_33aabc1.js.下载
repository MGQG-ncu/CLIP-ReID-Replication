/**
 * FileTreeView
 * @constructor
 */
function FileTreeView() {
    this.host = null;
    this.isInit = false;
    this.folderCache = null;
    this.spaceId = '';
}

// 获取埋点公参
function getLogPublicParams() {
    var file = (context.list.getSelected() || [])[0] || {};
    var fileList = window.locals.get('file_list') || [];
    var shareName = '';
    if (fileList && fileList.length && fileList[0].server_filename) {
        shareName = fileList[0].server_filename + (fileList.length > 1 ? '等' : '');
    }
    return {
        user_type: vipStatus.getVipValue() === 2 ? 'svip' : (vipStatus.getVipValue() === 0 ? 'norm' : 'other'),
        is_login: file.uk !== 0 ? 1 : 0,
        share_id: window.locals.get('shareid') || '',
        share_name: shareName || '',
        link_share_uk: window.locals.get('share_uk') || '',
    };
}

// 验证多人空间是否可用
// 返回 true 表示可用，false 表示不可用（已显示提示）
function validateCollabSpace(spaceId) {
    var collabSpaceList = window.locals.get('preFetchCollabSpaceList') || [];
    var spaceInfo = null;
    for (var i = 0; i < collabSpaceList.length; i++) {
        if (collabSpaceList[i].spaceId == spaceId) {
            spaceInfo = collabSpaceList[i]._originalSpace || collabSpaceList[i];
            break;
        }
    }
    if (!spaceInfo) {
        return true; // 没找到空间信息，放行
    }
    // 1. 判断空间是否到期
    var productExpireTime = spaceInfo.product_expire_times;
    var isExpired = productExpireTime != null && productExpireTime > 0;
    if (isExpired) {
        getContext().ui.tip({
            msg: '该空间已到期，不支持选择',
            mode: 'caution'
        });
        return false;
    }
    // 2. 判断是否是访客身份 (role: 4 = 访客)
    var role = spaceInfo.role;
    if (role === COLLAB_ROLE_VISITOR) {
        getContext().ui.tip({
            msg: '您是访客身份，暂不支持选择，如有需要请联系该空间管理员变更身份',
            mode: 'caution'
        });
        return false;
    }
    return true;
}

FileTreeView.ROOT = 0;
FileTreeView.NORMAL = 1;

FileTreeView.PARTICULAR_DIR_MAP = {
    '/': '/全部文件',
    '/_pcs_.workspace': '/全部文件',
    '/apps': '/我的应用数据',
    '/百度云收藏': '/百度云收藏',
    '/来自PC的备份文件': '/来自PC的备份文件',
    '/我的分享': '/我的分享',
    '/我的作品': '/我的作品'
};

FileTreeView.ENTERPRISE_PARTICULAR_DIR_MAP = {
    '/': '/全员可见',
    '/_pcs_.appdata/ent/sharedir/': '/群组可见'
};

FileTreeView.prototype.getParentPath = function (path) {
    return path.slice(0, path.lastIndexOf('/')) || '/';
};


FileTreeView.prototype.parseNameFromPath = function (path) {
    return path.substring(path.lastIndexOf('/') + 1, path.length);
};
FileTreeView.prototype.getNameFromPath = function (path, cid) {
    if (cid) {
        return FileTreeView.prototype.getNameFromEnterprisePath(path);
    }
    if (FileTreeView.PARTICULAR_DIR_MAP[path]) {
        return this.parseNameFromPath(FileTreeView.PARTICULAR_DIR_MAP[path]);
    } else {
        return this.parseNameFromPath(path);
    }
};
FileTreeView.prototype.getNameFromEnterprisePath = function (path) {
    if (FileTreeView.ENTERPRISE_PARTICULAR_DIR_MAP[path]) {
        return this.parseNameFromPath(FileTreeView.ENTERPRISE_PARTICULAR_DIR_MAP[path]);
    } else if (path === '/_pcs_.appdata/ent/personal/' + window.locals.get('uk')) {
        return '自己可见';
    } else {
        return this.parseNameFromPath(path);
    }
};

FileTreeView.prototype.build = function (host, params) {
    // if (this.isInit) {
    //     return;
    // }
    if (!host) {
        return;
    }
    var nodePath = '/';
    var url = '/api/list?channel=chunlei&bdstoken=' + window.locals.get('bdstoken');
    if (params && params.cid) {
        FileTreeView.prototype.cid = params.cid;
        url = '/mid_enterprise_v2' + url + '&cid=' + params.cid + '&app_id=24029990';
    } else if (params && (params.type === 'sync')) {
        folderCacheConfig.params.dir = '/_pcs_.workspace/';
        nodePath = '/_pcs_.workspace';
        url += (window.locals.get('preFetchIsWorkSpaceUser') ? '' : '&workspace_init=1');
    } else if (params && params.type === 'collab') {
        this.spaceId = params.spaceId || '';
        if (params.spaceId) {
            // 有 spaceId 时，不使用 folderCache，直接用 _buildCollabSpaceTreeView
            url = '';
        } else {
            // 没有 spaceId 时，显示团队空间列表（不调用文件夹接口）
            url = '';
        }
    } else {
        url += '&app_id=250528';
    }
    folderCacheConfig.api = url;
    this.host = $(host);
    this.folderCache === null && (this.folderCache = getContext().ui.listCache('foldTree', folderCacheConfig));
    this.handleEvent();

    if (params && params.cid) {
        var eNodes = {
            allfiles: {
                nodeRoot: true,
                themeClass: 'e-allfiles-theme',
                pdleft: 0,
                nodeOn: false,
                path: '/',
                permit: 300,
                permitOpList: util.eAllPermissions(),
                ownerUk: window.locals.get('uk'),
                cid: params.cid
            },
            sharedir: {
                nodeRoot: true,
                themeClass: 'e-sharedir-theme',
                pdleft: 0,
                nodeOn: false,
                path: '/_pcs_.appdata/ent/sharedir/',
                permit: 100,
                permitOpList: [],
                ownerUk: window.locals.get('uk'),
                cid: params.cid
            },
            personal: {
                nodeRoot: true,
                themeClass: 'e-personal-theme',
                pdleft: 0,
                nodeOn: false,
                path: '/_pcs_.appdata/ent/personal/' + window.locals.get('uk'),
                permit: 300,
                permitOpList: util.eAllPermissions(),
                ownerUk: window.locals.get('uk'),
                cid: params.cid
            }
        };
        var list = '<ul class="treeview treeview-content">'
            + this._tpl(eNodes.allfiles) + this._tpl(eNodes.sharedir) + this._tpl(eNodes.personal)
            + '</ul>';
        // 企业初始视图不展示 新建文件夹 与 确定 按钮
        $('.company-tree-newcreate').addClass('disabled');
        $('.company-tree-confirm').addClass('disabled');
    } else if (params && params.type === 'collab') {
        // 团队空间列表视图：显示所有团队空间
        var collabSpaceList = window.locals.get('preFetchCollabSpaceList') || [];
        var targetSpaceId = params.spaceId || ''; // 需要自动展开的空间
        var collabHtml = '';
        for (var i = 0; i < collabSpaceList.length; i++) {
            var space = collabSpaceList[i];
            // 判断空间是否不可用（已到期 或 访客身份），用于置灰处理
            var spaceInfo = space._originalSpace || space;
            var productExpireTime = spaceInfo.product_expire_times;
            var disabledReason = '';
            if (productExpireTime > 0) {
                disabledReason = 'expired';
            } else if (spaceInfo.role === COLLAB_ROLE_VISITOR) {
                disabledReason = 'visitor';
            }
            // 不可用空间（访客/已到期）不自动展开
            var isTarget = targetSpaceId && space.spaceId === targetSpaceId && !disabledReason;
            collabHtml += this._collabSpaceTpl({
                spaceId: space.spaceId,
                name: space.name,
                avatorImg: space.avatorImg,
                desc: space.desc,
                pdleft: 0,
                // 目标空间标记为展开状态
                minus: isTarget,
                nodeOn: isTarget,
                disabled: !!disabledReason,
                disabledReason: disabledReason,
                quota: spaceInfo.quota,
                quotaUsed: spaceInfo.quotaUsed
            });
        }
        var list = '<ul class="treeview treeview-content">' + collabHtml + '</ul>';
        // 如果有目标空间，启用确定按钮
        if (targetSpaceId) {
            $('.company-tree-confirm')
                .removeClass('disabled no-permit no-root-dir-permit')
                .attr('title', '确定');
            // 访客身份不能创建文件夹
            var targetSpaceEntry = (window.locals.get('preFetchCollabSpaceList') || []).filter(function (s) {
                return s.spaceId == targetSpaceId;
            })[0];
            var targetSpaceRole = targetSpaceEntry && (targetSpaceEntry._originalSpace || targetSpaceEntry).role;
            if (targetSpaceRole !== COLLAB_ROLE_VISITOR) {
                $('.company-tree-newcreate').removeClass('disabled no-root-dir-permit');
            }
            // 设置当前 spaceId
            this.spaceId = targetSpaceId;
        } else {
            // 团队空间初始视图不展示 新建文件夹 与 确定 按钮
            $('.company-tree-newcreate').addClass('disabled');
            $('.company-tree-confirm').addClass('disabled');
        }
    } else {
        var list = '<ul class="treeview treeview-content">' + this._tpl({
            nodeRoot: true,
            minus: true,
            pdleft: 0,
            nodeOn: true,
            path: nodePath,
            ownerUk: window.locals.get('uk')
        }) + '</ul>';
    }
    this.host.html(list);
    // this.isInit = true;
};

FileTreeView.prototype.refresh = function (params) {

    // if (!this.isInit) {
    //     return;
    // }
    var tmpDir = '/';
    if (params && params.cid) {
        return; // 企业不需要恢复缓存目录
    } else if (params && (params.type === 'sync')) {
        tmpDir = '/_pcs_.workspace';
    } else if (params && params.type === 'collab' && params.spaceId) {
        // 有 spaceId 时，自动展开该空间的文件夹
        var targetSpaceId = params.spaceId;
        // 找到目标空间的节点
        var $targetNode = this.host.find('.treeview-collab-space-theme[data-space-id="' + targetSpaceId + '"]');
        if ($targetNode.length > 0) {
            // 不可用空间（访客/已到期）不自动展开
            if ($targetNode.attr('data-disabled-reason')) {
                return;
            }
            var $nodeDiv = $targetNode.find('.treeview-node').first();
            var $collap = $nodeDiv.next('ul');
            var pdl = $nodeDiv.attr('_pl') || 0;
            // 加载该空间的文件夹列表
            this._buildCollabSpaceTreeView({
                spaceId: targetSpaceId,
                host: $collap,
                pl: parseInt(pdl) + 15,
                path: '/'
            });
        }
        return;
    } else if (params && params.type === 'collab' && !params.spaceId) {
        return; // 团队空间列表不需要恢复缓存目录
    }

    this._buildTreeView({
        dir: tmpDir,
        pl: 15
    });
};

