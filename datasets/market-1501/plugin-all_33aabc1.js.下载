                        ext: {
                            scene: 'web_video_details',
                            btn: 'fixed_pc'
                        }
                    });
                }
            });
        }
    } catch (error) {
        console.error(error);
    }
};

InvokeAppPopover.prototype.downloadMacApp = function(type) {
    pcInvoker.downloadSpecificApp(type);
};

