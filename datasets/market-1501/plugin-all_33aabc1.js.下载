                        // restapi.transfer err:0
                        var task_id = result.task_id;
                        if (!(result.errno === 0 && task_id > 0 && pri.conf.opts.isMulti)) {
                            shareTransferTimePerf.end();
                        }
                        if (task_id > 0 && pri.conf.opts.isMulti) {
                            pri.util.transferTip('系统正在为你保存，请稍候&hellip;', 'loading', type);
                            pri.util.transferTask(task_id, savepath, function () {
                                shareTransferTimePerf.end();
                            });
                        } else if (result.errno === 111) {
                            pri.util.transferTip(result.show_msg || errMap[result.errno], 'loading', type);
                        } else {
                            // task_id === 0
                            // 保存成功
                            // key值和v20-main中保持一致，用于转存文件高亮显示
                            localStorage.setItem('transfer_files_fsid', fsidlist);
                            var fsidArray = JSON.parse(fsidlist).map(Number);
                            var fsidListKey = 'transfer_files_' + window.locals.get('uk');
                            var localArray = JSON.parse(localStorage.getItem(fsidListKey)) || [];
                            var mergedArray = fsidArray.concat(localArray).filter((item, index, self) => self.indexOf(item) === index);
                            localStorage.setItem(fsidListKey, JSON.stringify(mergedArray));
                            pri.util.transferTaskSuccess(savepath);
                            pri.util.getFileInfo(result.extra.list, function (file) {
                                if (pri.conf.isOutLinkPdfToWordClick) {
                                    getContext().message.callPlugin('网盘PDF转Word@com.baidu.pan', {
                                        filesList: file
                                    });
                                }
                            });
                        }
                    } else if (result.errno === 111) {
                        // restapi.transfer err:111
                        pri.util.transferTip(result.show_msg || errMap[result.errno], 'loading', type);

                    } else if (result.errno === 12) {
                        // 这里对/api/ostp/share/sstransfer 做一个特殊处理，这里直接把 show_msg toast显示
                        if (param.url && param.url.indexOf('/api/ostp/share/sstransfer') !== -1) {
                            pri.util.transferTip(result.show_msg || errMap[result.errno]);
                            return;
                        }

                        // restapi.transfer err 12
                        var array = result.info || [];
                        var err;
                        var hideToast = false;

                        /**
                         * 错误码说明
                         *
                         * 120  超过免费用户上限    1000
                         * 130  超过普通会员上限    3000
                         * -33  超过超级会员上限    50000
                         */
                        for (var i = 0; i < array.length; i++) {
                            var eno = array[i].errno;
                            if (+eno === 0) {
                                continue;
                            }

                            hideToast = false;
                            var path = array[i].path;

                            // 针对转存数量问题
                            if (eno === -33 || eno === 120 || eno === 130) {
                                if (pri.util.targetSpaceIsEnterprise()) {
                                    var limitData = enterpriseProductBase.check('transferLimits');
                                    pri.conf.currentItem.maxTransferNumber = limitData.max; // 企业转存时支持的最大数量
                                    // 超过了最大值
                                    var exceedMax = result.target_file_nums > pri.conf.currentItem.maxTransferNumber;
                                    // 确认是企业主
                                    var isMaster = pri.conf.currentItem.role === 1;
                                    // 确认是免费版或者试用版
                                    // eslint-disable-next-line max-len
                                    var isFreeOrTryVersion = pri.conf.currentItem.productType === 0 || pri.conf.currentItem.productType === 1;
                                    // 目标是企业空间的转存超限逻辑
                                    // 如果是企业主 && 如果是免费版或者试用版 && 没有超过旗舰版的最大值(200000)
                                    if (isMaster && isFreeOrTryVersion && !exceedMax) {
                                        // 针对企业主的企业套餐付费引导 在这里才会触发
                                        // eslint-disable-next-line max-len
                                        enterpriseTransferGuideDialog(pri.conf.currentItem.productType, result.target_file_nums);
                                    } else {
                                        hideToast = true;
                                        // 使用 无法支持 弹窗
                                        enterpriseTransferUnsupportDialog({
                                            exceedMax: exceedMax,
                                            productType: pri.conf.currentItem.productType,
                                            cid: pri.conf.currentItem.cid
                                        });
                                    }
                                } else {
                                    // 普通空间的处理，走普通用户转存超限逻辑
                                    if (eno === -33) {
                                        hideToast = true;
                                        pri.util.showVipTips({
                                            type: 1,
                                            errMsg: '文件过多无法转存，减少点文件试试吧',
                                            smallContent: '超级会员尊享单次转存文件' + svipLimit + '个',
                                            buttonColor: 'blue'
                                        });
                                    } else if (eno === 120) {
                                        hideToast = true;
                                        getContext().log.send({
                                            type: 'wap_share_transfer_guide_show_normal_user_web'
                                        });
                                        transferGuideDialog(getContext(), eno, function () {
                                            pri.conf.force = 1;
                                            pri.util.serviceInit();
                                        });
                                    } else if (eno === 130) {
                                        hideToast = true;
                                        getContext().log.send({
                                            type: 'wap_share_transfer_guide_show_normal_user_web'
                                        });
                                        transferGuideDialog(getContext(), eno, function () {
                                            pri.conf.force = 1;
                                            pri.util.serviceInit();
                                        });
                                    }
                                }
                            } else if (eno === -32) {
                                // 空间不足
                                hideToast = true;
                                if (urlParams && urlParams.cid) {
                                    pri.util.transferTip(result.show_msg || errMap[eno]);
                                } else {
                                    transferGuideDialog(getContext(), eno, function () {
                                        pri.util.serviceInit();
                                    });
                                }
                            } else if (eno === -30 && pri.conf.isOutLinkPdfToWordClick) {
                                // 外链页点击 pdf 转存的时候，如果文件已保存的处理
                                hideToast = true;
                                var tempaArray = result.info[0].path.split('/');
                                var filePath = savepath + '/' + tempaArray[tempaArray.length - 1];
                                var originFsid = JSON.parse(param.data.fsidlist)[0];

                                pri.util.getFileInfo([{
                                    from_fs_id: originFsid,
                                    to: filePath
                                }], function (file) {
                                    getContext().message.callPlugin('网盘PDF转Word@com.baidu.pan', {
                                        filesList: file
                                    });
                                });
                            } else {
                                // NOTE
                                err = result.show_msg || errMap[eno] || getContext().errorMsg(eno);
                            }

                            err = err || '请稍候重试';
                            switch (eno) {
                                case -30:
                                    if (!pri.conf.isOutLinkPdfToWordClick) {
                                        err += createLink(savepath);
                                        pri.util.setTransferItem();
                                    }
                                    break;
                                default:
                                    break;
                            }
                            break;
                        }

                        if (!hideToast) {
                            pri.util.transferTip(err);
                        }
                    } else if (result.errno === -8) {
                        // 保存的文件已存在，冲突处理
                        pri.util.transferClash();
                    } else if (result.errno === -33) {
                        pri.util.showVipTips({
                            type: 1,
                            errMsg: result.show_msg || errMap[result.errno],
                            smallContent: '超级会员尊享单次转存文件' + svipLimit + '个',
                            buttonColor: 'blue'
                        });
                    } else if (result.errno === 120) {
                        pri.util.showVipTips({
                            type: 1,
                            errMsg: result.show_msg || errMap[result.errno]
                        });
                    } else if (result.errno === 130) {
                        pri.util.showVipTips({
                            type: 1,
                            errMsg: '所选文件数量超出' + vipLimit + '个上限，无法保存',
                            vipType: 'svip'
                        });
                    } else if (result.errno === -10) {
                        // 空间不足
                        pri.util.showVipTips({
                            type: 0
                        });
                    } else if (result.errno === 20025) {
                        pri.util.transferTip('页面过期，请刷新后重试');
                    } else if (pri.util.targetSpaceIsEnterprise() && (result.errno === 3010 || result.errno === 3011)) {
                        // 转存到企业限制： 3010, "群组可见空间不可用，请联系管理员", 3011, "本人可用存储空间不足"
                        pri.util.transferTip(result.show_msg);
                    } else if (result.errno === 2) {
                        pri.util.transferTip('保存失败，请修改保存路径后重试');
                    } else if (result.errno === 4 && result.duplicated && result.duplicated.total > 0) {
                        pri.util.transferTip('该路径下已有相同文件，无需再次保存');
                    } else {
                        // restapi.transfer error
                        pri.util.transferTip(errMap[result.errno] || '保存失败，请稍后重试');
                    }
                    if (pri.conf.opts.callback && typeof pri.conf.opts.callback === 'function') {
                        if (urlParams && urlParams.cid) {
                            result.cid = urlParams.cid;
                        }
                        pri.conf.opts.callback(savepath, result);
                    }
                }
            });
        },
        /**
         * 获取文件信息，通过 sessionStorage 存储到本地，供转为 word 使用
         * @param {string} filePath
         * @param {string} originFsid
         */
        getFileInfo: function (fileList, callback) {
            var filePath = [];
            var filePathFsidMap = {};
            for (var i = 0; i < fileList.length; i++) {
                filePath.push(fileList[i].to);
                filePathFsidMap[fileList[i].to] = fileList[i].from_fs_id;
            }

            $.ajax({
                url: '/api/filemetas',
                data: {
                    target: JSON.stringify(filePath),
                    dlink: 1
                },
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    if (data.errno === 0) {
                        // IE67 不支持 sessionStorage
                        if (typeof window.attachEvent !== 'undefined' && typeof window.sessionStorage !== 'object') {
                            // 本质是走了 js cache
                            for (var i = 0; i < data.info.length; i++) {
                                var fileInfo = data.info[i];
                                storage.setItem(filePathFsidMap[fileInfo.path], JSON.stringify([fileInfo]));
                            }
                        } else {
                            for (var i = 0; i < data.info.length; i++) {
                                var fileInfo = data.info[i];
                                sessionStorage.setItem(filePathFsidMap[fileInfo.path], JSON.stringify([fileInfo]));
                            }
                        }
                        callback && callback(data.info);
                    } else {
                        if (pri.conf.isOutLinkPdfToWordClick) {
                            pri.util.transferTip('文件信息获取失败！');
                        }
                    }
                },
                error: function (data) {
                    if (pri.conf.isOutLinkPdfToWordClick) {
                        pri.util.transferTip('网络错误，请稍后重试');
                    }
                }
            });
        },
