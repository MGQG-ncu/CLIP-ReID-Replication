FileTreeView.prototype.setShareDirApi = function () {
    folderCacheConfig._api = folderCacheConfig.api;
    folderCacheConfig._params = JSON.parse(JSON.stringify(folderCacheConfig.params));
    folderCacheConfig.api = '/mid_enterprise_v2/api/enterprise/sharedir/getlist';
    folderCacheConfig.params.dir = '/';
    folderCacheConfig.params.limit = '300';
    folderCacheConfig.params.cid = FileTreeView.prototype.cid;
