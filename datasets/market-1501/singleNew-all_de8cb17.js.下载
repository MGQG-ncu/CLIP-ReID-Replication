function showLimitDialog(options) {
    pcInvokerLog.send('webEvokedBtnDis', {
        page: 'audio_details', // 当前该插件仅在单文件音频落地页调用
        ext: {
            scene: 'share_link',
            btn: 'share_audio_limit'
        }
    });

    options = options || {};
    options.filesList = options.filesList || [];

    if (pri.lastDialog) {
        pri.lastDialog.$dialog.removeClass('dialog2024-new').addClass('dialog2024-new');
    }

    var dialog = context.ui.confirm({
        title: '试听结束，你可以选择',
        className: 'dialog2024 dialog2024-new',
        width: '660px',
        outerHeight: '254px',
        body: `<div class="video-over-tip-inner audio-inner-wrap">
                    <div class="video-over-tip-inner-left audio-inner-left">
                        <div class="text">保存音频</div>
                        <div class="desc">保存后可收听完整音频</div>
                    </div>
                    <div class="video-over-tip-inner-right audio-inner-right">
                        <div class="text">直接在电脑端收听</div>
                        <div class="recommend">推荐</div>
                        <div class="desc">不想保存音频，前往网盘电脑端</div>
                    </div>
                </div>`,
        sureText: '立即保存',
        cancelText: '打开电脑端',
        onSure: function () {
            context.message.callPlugin('保存到网盘@com.baidu.pan.share', {
                filesList: options.filesList,
                isFileConsumeScene: true
            });
            dialog.hide();
            audioPreviewLog.send('saveAudio');
        },
        onCancel: function () {
            context.message.callPlugin('网盘外链-调端@com.baidu.pan', {
                btn: 'share_audio_limit'
            });
            dialog.hide();
            audioPreviewLog.send('goApp');
        }
    });

    pri.lastDialog = dialog;

    return dialog;
}

function showSimpleDialog(op, options) {
    if (pri.lastDialog) {
        pri.lastDialog.$dialog.removeClass('dialog2024-new');
    }

    var dialogOptions = $.extend({
        title: '提示',
        className: 'dialog2024 dialog-audio-preview',
        width: '464px',
        body: '',
        draggable: false,
        position: {
            xy: 'center'
        },
        sureText: '取消',
        cancelText: '打开电脑端',
        onSure: function () {
            dialog.hide();
        }
    }, options, {
        body: '<div style="margin-top: -4px;padding: 0 0 6px 0;font-weight: 400;">' + options.body + '</div>'
    });

    dialog = context.ui.confirm(dialogOptions);
    pri.lastDialog = dialog;
    pcInvokerLog.send('webEvokedBtnDis', {
        page: 'audio_details', // 当前该插件仅在单文件音频落地页调用
        ext: {
            scene: 'share_link',
            btn: 'share_audio_' + op
        }
    });

    return dialog;
}

function onCreatedPlayer(player) {
    var file = window.locals.get('file_list')[0];

    player.on('timeupdate', function () {
        player.getCurrentAudioInfo().then(function (info) {
            info = info || {};

            if (info.error === 0) {
                var currentTime = info.info.currentTime;

                if (currentTime > pri.limitTime) {
                    player.pause();
                    pri.limited = true;
                    showLimitDialog();
                    audioPreviewLog.send('playbackEndPopup');
                }
            }
        });
    });
    player.on('error', function (errorInfo) {
        var errorData = errorInfo.data || {};
        var response = errorData.response || {};
        var responseDataStr = response.data || '{}';
        var errorResult = {
            name: file.server_filename,
            size: file.size,
            error_type: errorInfo.event || '',
            error_no: errorInfo.error,
            error_reason: errorData.reason || '',
        };

        try {
            var responseData = JSON.parse(responseDataStr);

            if (typeof responseData.errno !== 'undefined') {
                errorResult.errno = responseData.errno;
            }
        } catch (e) {
            console.error('Error parsing response:', e);
        }

        var errno = errorResult.errno;
        var errorMsg = '';

        if (errno === 31346) {
            errorMsg = '加载失败了，稍候重试一下吧';
        } else if (errno === 31066 || (response.code === 404)) {
            errorMsg = '文件不存在，换一个吧！';
        } else if (errno === 31339) {
            // 非法音频
            errorMsg = '该音频无法播放噢，换一个试试吧！';
        } else if (errno === 31341) {
            // 转码中
            errorMsg = '音频正在转码中，稍后再来试下吧...';
        } else if (errno === 31346) {
            // 转码失败
            errorMsg = '抱歉，音频转码失败了，请换一个试试吧！';
        } else if (errno === 31304) {
            // 格式不支持
            errorMsg = '文件格式不支持在线播放～';
        } else if (errno === 31347) {
            errorMsg = '音频过长暂不支持在线播放～';
        } else if (errno === 31338) {
            errorMsg = '该音频分辨率或码率太高暂不支持在线播放～';
        } else if (errno === 31023) {
            errorMsg = '文件异常，请刷新后重试～';
        } else if (errno === 31391) {
            errorMsg = '文件违规，已根据相关法律法规予以屏蔽';
        } else if (errno === 31326 || errno === 31426) {
            errorMsg = '音频播放失败';
        } else {
            errorMsg = navigator.onLine ? '音频播放失败，请稍后重试～' : '网络异常，请联网后重试～';
        }

        context.ui.tip({
            mode: 'caution',
            msg: errorMsg || '播放失败，请稍后再试',
            sticky: false
        });
        audioPreviewLog.send('playError', {
            ext: errorResult
        });

        return errorResult;
    });
    player.on('ended', function () {
        showLimitDialog();
    });
    player.on('playing', function () {
        audioPreviewLog.send('playSuccess', {
            ext: {
                name: file.server_filename,
                size: file.size
            }
        });
    });
}

window.locals.get('sign', 'timestamp', 'share_uk', 'shareid', function (sign, stamp, shareUK, shareid) {
    function getUrl(file) {
        return location.protocol + '//' + location.host
            + '/share/streaming?channel=chunlei&uk=' + shareUK
            + '&fid=' + file.fs_id
            + '&sign=' + sign
            + '&timestamp=' + stamp
            + '&shareid=' + shareid
            + '&type=M3U8_MP3_128'
            + '&vip=' + vipStatus.getVipValue()
            + '&jsToken=' + window.jsToken;
    }

    var file = window.locals.get('file_list')[0];
    var playerOptions = {
        hls: {
            overrideNative: true
        },
        list: [
            {
                type: 'm3u8',
                url: getUrl(file)
            }
        ]
    };

    context.message.callPlugin('网盘音频播放器@com.baidu.pan', {
        flag: 'share_audio',
        container: $('#MboxWraper'),
        file: file,
        filesList: window.locals.get('file_list'),
        inDialog: false,
        isNewShare: true,
        playerOptions,
        eventHandlerMap: {
            play: function () {
                if (pri.player) {
                    if (pri.limited) {
                        pri.player.seek();
                        pri.limited = false;
                    } else {
                        pri.player.play();
                        audioPreviewLog.send('audioPlay');
                    }
                }

                return false;
            },
            loop: function () {
                var dialog = showSimpleDialog('loop', {
                    body: '网页版不支持自定义播放顺序，请打开电脑端使用',
                    onCancel: function () {
                        context.message.callPlugin('网盘外链-调端@com.baidu.pan', {
                            btn: 'share_audio_loop'
                        });
                        dialog.hide();
                    }
                });
            },
            prev: function () {
                var dialog = showSimpleDialog('prev', {
                    body: '网页版不支持选集，请打开电脑端使用',
                    onCancel: function () {
                        context.message.callPlugin('网盘外链-调端@com.baidu.pan', {
                            btn: 'share_audio_prev'
                        });
                        dialog.hide();
                    }
                });
            },
            next: function () {
                var dialog = showSimpleDialog('next', {
                    body: '网页版不支持选集，请打开电脑端使用',
                    onCancel: function () {
                        context.message.callPlugin('网盘外链-调端@com.baidu.pan', {
                            btn: 'share_audio_next'
                        });
                        dialog.hide();
                    }
                });
            },
            draft: function () {
                var dialog = showSimpleDialog('draft', {
                    body: '网页版不支持语音转文字功能，请打开电脑端使用',
                    onCancel: function () {
                        context.message.callPlugin('网盘外链-调端@com.baidu.pan', {
                            btn: 'share_audio_draft'
                        });
                        dialog.hide();
                        audioPreviewLog.send('speechToApp');
                    }
                });

                audioPreviewLog.send('speechToText');
                audioPreviewLog.send('speechToTextPopup');
            }
        },
        callback: function (player) {
            pri.player = player;
            onCreatedPlayer(player);
        }
    });
});
 
